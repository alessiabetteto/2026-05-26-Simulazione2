                def _ricorsione_path(self, parziale, target_end, target_len, current_weight):
                    # 1. CONDIZIONE DI TERMINAZIONE (Lunghezza fissata)
                    # Se ho raggiunto la lunghezza target (numero di archi = Lun, quindi nodi = Lun + 1)
                    if len(parziale) - 1 == target_len:
                        # Controllo se sono arrivato al nodo corretto
                        if parziale[-1] == target_end:
                            # Controllo se è il peso migliore
                            if current_weight > self.best_score:
                                self.best_score = current_weight
                                self.best_path = list(parziale)
                        return # Fondamentale tornare indietro

                    # 2. ESPLORAZIONE
                    ultimo = parziale[-1]

                    # Se il grafo è orientato, usa .successors(), altrimenti .neighbors()
                    for vicino in self.grafo.neighbors(ultimo):
                        if vicino not in parziale: # Cammino semplice

                            peso_arco = self.grafo[ultimo][vicino]['weight']

                            # Passo ricorsivo con backtracking
                            parziale.append(vicino)
                            self._ricorsione_path(parziale, target_end, target_len, current_weight + peso_arco)
                            parziale.pop()






